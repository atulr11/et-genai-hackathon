<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
  :root {
    --gold: #C9A84C;
    --gold-light: #E8C97A;
    --dark: #0D0D0D;
    --dark2: #161616;
    --dark3: #1F1F1F;
    --card: #1A1A1A;
    --border: rgba(201,168,76,0.2);
    --text: #F0EDE6;
    --muted: #8A8578;
    --green: #2ECC71;
    --red: #E74C3C;
    --blue: #3498DB;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    background: var(--dark);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* NOISE OVERLAY */
  body::before {
    content:'';
    position:fixed; inset:0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events:none; z-index:0; opacity:0.4;
  }

  /* HEADER */
  header {
    display:flex; align-items:center; justify-content:space-between;
    padding: 20px 40px;
    border-bottom: 1px solid var(--border);
    position:relative; z-index:10;
    background: rgba(13,13,13,0.95);
    backdrop-filter: blur(12px);
  }
  .logo {
    display:flex; align-items:center; gap:12px;
  }
  .logo-et {
    background: var(--gold);
    color: var(--dark);
    font-family: 'Playfair Display', serif;
    font-weight:900; font-size:18px;
    padding: 4px 10px;
    letter-spacing:2px;
  }
  .logo-text {
    font-family:'Playfair Display', serif;
    font-size:16px; font-weight:400;
    color: var(--gold-light);
    letter-spacing:1px;
  }
  .logo-badge {
    font-size:10px; background: rgba(201,168,76,0.15);
    border:1px solid var(--border);
    color: var(--gold);
    padding:3px 8px; border-radius:20px;
    letter-spacing:1px; text-transform:uppercase;
  }
  nav { display:flex; gap:8px; }
  .nav-btn {
    background:none; border:none; color:var(--muted);
    font-family:'DM Sans',sans-serif; font-size:13px;
    padding:8px 16px; cursor:pointer; border-radius:6px;
    transition:all 0.2s;
  }
  .nav-btn:hover, .nav-btn.active {
    background: rgba(201,168,76,0.1);
    color: var(--gold);
  }
  .nav-btn.active { border-bottom: 2px solid var(--gold); }

  /* HERO */
  .hero {
    text-align:center;
    padding: 70px 40px 40px;
    position:relative; z-index:2;
  }
  .hero-tag {
    display:inline-block;
    font-size:11px; letter-spacing:3px; text-transform:uppercase;
    color:var(--gold); border:1px solid var(--border);
    padding:6px 16px; border-radius:20px; margin-bottom:24px;
  }
  .hero h1 {
    font-family:'Playfair Display',serif;
    font-size:clamp(36px,6vw,72px); font-weight:900;
    line-height:1.05; margin-bottom:20px;
  }
  .hero h1 span { color:var(--gold); }
  .hero p {
    font-size:16px; color:var(--muted); max-width:520px;
    margin:0 auto 40px; line-height:1.7;
  }
  .cta-row { display:flex; gap:16px; justify-content:center; flex-wrap:wrap; }
  .btn-primary {
    background: linear-gradient(135deg, var(--gold), #A07830);
    color:var(--dark); font-weight:600; font-size:14px;
    padding:14px 32px; border:none; border-radius:8px;
    cursor:pointer; transition:all 0.3s; letter-spacing:0.5px;
  }
  .btn-primary:hover { transform:translateY(-2px); box-shadow:0 8px 30px rgba(201,168,76,0.3); }
  .btn-secondary {
    background:none; border:1px solid var(--border);
    color:var(--text); font-size:14px; padding:14px 32px;
    border-radius:8px; cursor:pointer; transition:all 0.2s;
  }
  .btn-secondary:hover { border-color:var(--gold); color:var(--gold); }

  /* STATS ROW */
  .stats-row {
    display:flex; justify-content:center; gap:40px;
    padding:30px 40px;
    border-top:1px solid var(--border);
    border-bottom:1px solid var(--border);
    position:relative; z-index:2;
  }
  .stat { text-align:center; }
  .stat-num {
    font-family:'Playfair Display',serif;
    font-size:28px; font-weight:700; color:var(--gold);
  }
  .stat-label { font-size:12px; color:var(--muted); margin-top:4px; }

  /* MAIN CONTENT */
  .main { max-width:1100px; margin:0 auto; padding:40px 24px; position:relative; z-index:2; }

  /* TABS */
  .tabs {
    display:flex; gap:4px; margin-bottom:32px;
    background:var(--card); border-radius:12px;
    padding:6px; border:1px solid var(--border);
  }
  .tab {
    flex:1; padding:12px; text-align:center;
    border:none; border-radius:8px;
    font-family:'DM Sans',sans-serif; font-size:13px; font-weight:500;
    cursor:pointer; transition:all 0.25s;
    background:none; color:var(--muted);
  }
  .tab.active {
    background: rgba(201,168,76,0.15);
    color:var(--gold); border:1px solid var(--border);
  }

  /* PANEL */
  .panel { display:none; animation: fadeIn 0.4s ease; }
  .panel.active { display:block; }
  @keyframes fadeIn { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }

  /* CARD */
  .card {
    background:var(--card); border:1px solid var(--border);
    border-radius:16px; padding:28px; margin-bottom:20px;
  }
  .card-title {
    font-family:'Playfair Display',serif;
    font-size:20px; font-weight:700; margin-bottom:6px;
  }
  .card-sub { font-size:13px; color:var(--muted); margin-bottom:24px; }

  /* FORM */
  .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  @media(max-width:600px){ .form-grid{grid-template-columns:1fr;} }
  .form-group { display:flex; flex-direction:column; gap:6px; }
  .form-group label { font-size:12px; color:var(--muted); text-transform:uppercase; letter-spacing:1px; }
  .form-group input, .form-group select {
    background:var(--dark2); border:1px solid var(--border);
    border-radius:8px; padding:12px 14px;
    color:var(--text); font-family:'DM Sans',sans-serif; font-size:14px;
    outline:none; transition:border 0.2s;
  }
  .form-group input:focus, .form-group select:focus {
    border-color:var(--gold);
    box-shadow:0 0 0 3px rgba(201,168,76,0.1);
  }
  .form-group select option { background:var(--dark2); }
  .range-wrap { position:relative; }
  input[type=range] {
    -webkit-appearance:none; width:100%;
    height:4px; border-radius:4px;
    background: linear-gradient(to right, var(--gold) 0%, var(--dark3) 0%);
    border:none; padding:0; cursor:pointer;
  }
  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance:none; width:18px; height:18px;
    border-radius:50%; background:var(--gold);
    border:3px solid var(--dark); cursor:pointer;
  }
  .range-val {
    position:absolute; right:0; top:-22px;
    font-size:13px; color:var(--gold); font-weight:600;
  }

  /* SCORE DISPLAY */
  .score-container {
    display:flex; align-items:center; justify-content:center;
    flex-direction:column; padding:32px;
  }
  .score-circle {
    width:160px; height:160px; border-radius:50%;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    position:relative; margin-bottom:16px;
  }
  .score-circle svg { position:absolute; top:0; left:0; transform:rotate(-90deg); }
  .score-num {
    font-family:'Playfair Display',serif;
    font-size:48px; font-weight:900; color:var(--gold);
    position:relative; z-index:2;
  }
  .score-label { font-size:11px; color:var(--muted); z-index:2; letter-spacing:1px; }
  .score-grade {
    font-family:'Playfair Display',serif;
    font-size:22px; font-weight:700;
    margin-bottom:6px;
  }
  .score-desc { font-size:13px; color:var(--muted); text-align:center; max-width:300px; }

  /* DIMENSION BARS */
  .dimensions { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-top:24px; }
  @media(max-width:600px){ .dimensions{grid-template-columns:1fr;} }
  .dim-item { background:var(--dark2); border-radius:10px; padding:16px; }
  .dim-header { display:flex; justify-content:space-between; margin-bottom:10px; }
  .dim-name { font-size:13px; font-weight:500; }
  .dim-score { font-size:13px; color:var(--gold); font-weight:600; }
  .dim-bar { height:4px; background:var(--dark3); border-radius:4px; overflow:hidden; }
  .dim-fill {
    height:100%; border-radius:4px;
    background: linear-gradient(90deg, var(--gold), var(--gold-light));
    transition: width 1s ease;
  }
  .dim-fill.low { background: linear-gradient(90deg, var(--red), #ff6b6b); }
  .dim-fill.mid { background: linear-gradient(90deg, #F39C12, #F1C40F); }

  /* FIRE PLANNER */
  .fire-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; margin-top:16px; }
  @media(max-width:700px){ .fire-grid{grid-template-columns:1fr;} }
  .fire-card {
    background:var(--dark2); border:1px solid var(--border);
    border-radius:12px; padding:20px; text-align:center;
  }
  .fire-icon { font-size:28px; margin-bottom:10px; }
  .fire-val {
    font-family:'Playfair Display',serif;
    font-size:24px; font-weight:700; color:var(--gold);
  }
  .fire-lbl { font-size:12px; color:var(--muted); margin-top:4px; }

  /* TIMELINE */
  .timeline { margin-top:24px; position:relative; }
  .timeline::before {
    content:''; position:absolute; left:20px; top:0; bottom:0;
    width:2px; background:var(--border);
  }
  .tl-item {
    display:flex; gap:16px; margin-bottom:20px; position:relative;
  }
  .tl-dot {
    width:12px; height:12px; border-radius:50%;
    background:var(--gold); margin-top:4px; flex-shrink:0;
    margin-left:14px; z-index:1; border:2px solid var(--dark);
  }
  .tl-content { flex:1; }
  .tl-year { font-size:12px; color:var(--gold); font-weight:600; letter-spacing:1px; }
  .tl-action { font-size:14px; font-weight:500; margin:2px 0; }
  .tl-detail { font-size:12px; color:var(--muted); }

  /* CHAT */
  .chat-window {
    background:var(--dark2); border:1px solid var(--border);
    border-radius:16px; height:420px; overflow-y:auto;
    padding:20px; margin-bottom:16px;
    scroll-behavior:smooth;
  }
  .chat-window::-webkit-scrollbar { width:4px; }
  .chat-window::-webkit-scrollbar-track { background:transparent; }
  .chat-window::-webkit-scrollbar-thumb { background:var(--border); border-radius:4px; }
  .msg { display:flex; gap:12px; margin-bottom:20px; }
  .msg.user { flex-direction:row-reverse; }
  .msg-avatar {
    width:34px; height:34px; border-radius:50%;
    display:flex; align-items:center; justify-content:center;
    font-size:14px; flex-shrink:0;
    background: rgba(201,168,76,0.2);
    border:1px solid var(--border);
  }
  .msg.user .msg-avatar { background:rgba(52,152,219,0.2); border-color:rgba(52,152,219,0.3); }
  .msg-bubble {
    max-width:75%; background:var(--card);
    border:1px solid var(--border); border-radius:12px;
    padding:12px 16px; font-size:14px; line-height:1.6;
  }
  .msg.user .msg-bubble {
    background:rgba(52,152,219,0.1); border-color:rgba(52,152,219,0.2);
  }
  .msg-bubble strong { color:var(--gold); }
  .chat-input-row { display:flex; gap:10px; }
  .chat-input {
    flex:1; background:var(--dark2); border:1px solid var(--border);
    border-radius:10px; padding:12px 16px;
    color:var(--text); font-family:'DM Sans',sans-serif; font-size:14px;
    outline:none;
  }
  .chat-input:focus { border-color:var(--gold); }
  .chat-send {
    background:var(--gold); color:var(--dark);
    border:none; border-radius:10px; padding:12px 20px;
    font-weight:600; font-size:14px; cursor:pointer;
    transition:all 0.2s;
  }
  .chat-send:hover { background:var(--gold-light); }
  .typing { display:flex; gap:4px; align-items:center; padding:4px 0; }
  .typing span {
    width:6px; height:6px; border-radius:50%;
    background:var(--gold); animation:bounce 1.2s infinite;
  }
  .typing span:nth-child(2){animation-delay:0.2s;}
  .typing span:nth-child(3){animation-delay:0.4s;}
  @keyframes bounce {
    0%,80%,100%{transform:translateY(0)}
    40%{transform:translateY(-6px)}
  }

  /* QUICK QUESTIONS */
  .quick-qs { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px; }
  .quick-q {
    font-size:12px; padding:8px 14px;
    background:var(--dark2); border:1px solid var(--border);
    border-radius:20px; cursor:pointer; transition:all 0.2s;
    color:var(--muted);
  }
  .quick-q:hover { border-color:var(--gold); color:var(--gold); }

  /* RESULT SECTION */
  .result-section { display:none; }
  .result-section.show { display:block; animation:fadeIn 0.5s ease; }

  /* ALERTS */
  .alert {
    padding:14px 18px; border-radius:10px; font-size:13px;
    margin-bottom:12px; display:flex; gap:10px; align-items:flex-start;
  }
  .alert-warn { background:rgba(231,76,60,0.1); border:1px solid rgba(231,76,60,0.3); color:#ff8a80; }
  .alert-good { background:rgba(46,204,113,0.1); border:1px solid rgba(46,204,113,0.3); color:#69f0ae; }
  .alert-info { background:rgba(52,152,219,0.1); border:1px solid rgba(52,152,219,0.3); color:#82cfff; }

  /* FOOTER */
  footer {
    text-align:center; padding:30px;
    border-top:1px solid var(--border);
    font-size:12px; color:var(--muted);
    position:relative; z-index:2;
    margin-top:40px;
  }
  footer span { color:var(--gold); }

  /* LOADING SPINNER */
  .spinner {
    display:inline-block; width:16px; height:16px;
    border:2px solid rgba(201,168,76,0.3);
    border-top-color:var(--gold); border-radius:50%;
    animation:spin 0.8s linear infinite; vertical-align:middle; margin-right:6px;
  }
  @keyframes spin{to{transform:rotate(360deg)}}

  .pill {
    display:inline-block; font-size:11px; padding:3px 10px;
    border-radius:20px; font-weight:500; margin-left:8px;
  }
  .pill-green { background:rgba(46,204,113,0.15); color:var(--green); }
  .pill-red { background:rgba(231,76,60,0.15); color:var(--red); }
  .pill-gold { background:rgba(201,168,76,0.15); color:var(--gold); }

  /* SIP TABLE */
  table { width:100%; border-collapse:collapse; font-size:13px; }
  th { text-align:left; padding:10px 14px; color:var(--muted); font-weight:500;
    border-bottom:1px solid var(--border); font-size:11px; letter-spacing:1px; text-transform:uppercase; }
  td { padding:12px 14px; border-bottom:1px solid rgba(255,255,255,0.04); }
  tr:hover td { background:rgba(201,168,76,0.03); }
  td:last-child { color:var(--gold); font-weight:600; }
</style>
</head>
