      <button class="btn-primary" onclick="calculateFIRE()">Generate My FIRE Roadmap â†’</button>
    </div>

    <div class="result-section" id="fire-result">
      <div class="card">
        <div class="card-title">Your FIRE Numbers</div>
        <div class="fire-grid" id="fire-cards"></div>
      </div>
      <div class="card">
        <div class="card-title">ðŸ“… Year-by-Year Roadmap</div>
        <div class="card-sub">Key milestones on your path to financial independence</div>
        <div class="timeline" id="fire-timeline"></div>
      </div>
      <div class="card" id="fire-advice">
        <div class="card-title">âš¡ Accelerate Your FIRE</div>
        <div id="fire-tips"></div>
      </div>
    </div>
  </div>

  <!-- CHAT PANEL -->
  <div class="panel" id="panel-chat">
    <div class="card">
      <div class="card-title">ðŸ’¬ AI Financial Advisor</div>
      <div class="card-sub">Ask anything about your finances â€” powered by Claude AI.</div>

      <div class="quick-qs">
        <div class="quick-q" onclick="sendQuick(this.textContent)">Should I prepay my home loan?</div>
        <div class="quick-q" onclick="sendQuick(this.textContent)">Old vs new tax regime?</div>
        <div class="quick-q" onclick="sendQuick(this.textContent)">Best SIP for â‚¹10,000/month?</div>
        <div class="quick-q" onclick="sendQuick(this.textContent)">How much term insurance do I need?</div>
        <div class="quick-q" onclick="sendQuick(this.textContent)">NPS vs PPF vs ELSS â€” which is better?</div>
