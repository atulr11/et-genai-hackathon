    <div class="card">
      <div class="card-title">ðŸ”¥ FIRE Path Calculator</div>
      <div class="card-sub">Financial Independence, Retire Early â€” your personalized roadmap.</div>
      <div class="form-grid">
        <div class="form-group">
          <label>Current Age</label>
          <input type="number" id="f-age" value="28" min="18" max="55"/>
        </div>
        <div class="form-group">
