</div>

<footer>
  Built for <span>ET AI Hackathon 2026</span> Â· Problem Statement 9: AI Money Mentor Â· 
  Powered by <span>Claude AI + Anthropic</span>
</footer>

<script>
  // â”€â”€ HELPERS â”€â”€
  function showSection(s){
    ['health','fire','chat'].forEach(x=>{
      document.getElementById('panel-'+x).classList.remove('active');
      document.getElementById('tab-'+x).classList.remove('active');
    });
    document.getElementById('panel-'+s).classList.add('active');
    document.getElementById('tab-'+s).classList.add('active');
  }
  function showTab(t){
    if(t==='fire') showSection('fire');
    else if(t==='chat') showSection('chat');
    else showSection('health');
  }
  function scrollToMain(){ document.getElementById('main').scrollIntoView({behavior:'smooth'}); }
  function fmt(n){ return 'â‚¹'+Number(n).toLocaleString('en-IN'); }
  function updateRange(el){
    const pct = (el.value-el.min)/(el.max-el.min)*100;
    el.style.background=`linear-gradient(to right,var(--gold) ${pct}%,var(--dark3) ${pct}%)`;
  }
  document.querySelectorAll('input[type=range]').forEach(updateRange);

  // â”€â”€ HEALTH SCORE â”€â”€
  function calculateScore(){
    const income   = +document.getElementById('h-income').value || 80000;
    const expenses = +document.getElementById('h-expenses').value || 50000;
    const ef       = +document.getElementById('h-emergency').value;
    const sip      = +document.getElementById('h-sip').value || 10000;
    const debt     = +document.getElementById('h-debt').value || 0;
    const ins      = document.getElementById('h-insurance').value;
    const tax      = document.getElementById('h-tax').value;
    const retire   = document.getElementById('h-retire').value;

    const savingsRate = (income-expenses)/income;

    // Dimension scores (0-100 each)
    const dims = [
      {
        name:'Emergency Fund', icon:'ðŸ¦',
        score: Math.min(100, (ef/6)*100),
        ideal:'6 months of expenses',
        current: ef+' months'
      },
      {
        name:'Investment Rate', icon:'ðŸ“ˆ',
        score: Math.min(100, (sip/income)*500),
        ideal:'20% of income',
        current: Math.round((sip/income)*100)+'%'
      },
      {
        name:'Debt Health', icon:'ðŸ’³',
        score: debt===0?100: Math.max(0, 100-Math.min(100,(debt/(income*12))*100)),
        ideal:'< 12 months income',
        current: fmt(debt)
      },
      {
        name:'Insurance Cover', icon:'ðŸ›¡ï¸',
        score: ins==='none'?10:ins==='basic'?50:ins==='good'?80:100,
        ideal:'Term + Health + Life',
        current: ins==='none'?'None':ins==='basic'?'Basic':ins==='good'?'Good':'Excellent'
      },
      {
        name:'Tax Efficiency', icon:'ðŸ“‹',
        score: tax==='none'?10:tax==='partial'?50:tax==='full'?80:100,
        ideal:'80C + NPS + HRA',
        current: tax==='none'?'Not optimised':tax==='partial'?'Partial':tax==='full'?'80C done':'Fully optimised'
      },
      {
        name:'Retirement Ready', icon:'ðŸŒ…',
        score: retire==='none'?5:retire==='epf'?30:retire==='active'?70:100,
        ideal:'Active corpus building',
        current: retire==='none'?'Not started':retire==='epf'?'EPF only':retire==='active'?'Investing':' On track'
      }
    ];

    const total = Math.round(dims.reduce((a,d)=>a+d.score,0)/dims.length);

    // Animate score
    document.getElementById('score-result').classList.add('show');
    animateScore(total);
    document.getElementById('score-grade').textContent = total>=80?'ðŸ’Ž Excellent':total>=60?'âœ… Good':total>=40?'âš ï¸ Needs Work':'ðŸš¨ Critical';
    document.getElementById('score-desc').textContent = total>=80?'Your finances are in great shape. Focus on optimizing further.':
      total>=60?'Solid foundation. A few targeted actions can take you to excellent.':
      total>=40?'You have the basics but significant gaps need addressing.':
      'Immediate action needed. Start with emergency fund and insurance.';

    // Dimension bars
    const dc = document.getElementById('dim-container');
    dc.innerHTML = dims.map(d=>`
      <div class="dim-item">
        <div class="dim-header">
          <span class="dim-name">${d.icon} ${d.name}</span>
          <span class="dim-score">${Math.round(d.score)}/100</span>
        </div>
        <div class="dim-bar"><div class="dim-fill ${d.score<40?'low':d.score<70?'mid':''}" style="width:0%" data-w="${d.score}%"></div></div>
        <div style="font-size:11px;color:var(--muted);margin-top:6px">${d.current} Â· Target: ${d.ideal}</div>
      </div>
    `).join('');
    setTimeout(()=>{
      document.querySelectorAll('.dim-fill').forEach(b=>b.style.width=b.dataset.w);
    },100);

    // Alerts / action plan
    const alerts = [];
    if(ef<6) alerts.push({type:'warn',msg:`ðŸ¦ Build emergency fund to 6 months (${fmt((6-ef)*expenses)} more needed). Park in liquid funds or FD.`});
    if(sip/income < 0.2) alerts.push({type:'warn',msg:`ðŸ“ˆ Increase SIP to ${fmt(Math.round(income*0.2))} (20% of income). Even â‚¹500 extra monthly compounds hugely over time.`});
    if(ins==='none'||ins==='basic') alerts.push({type:'warn',msg:`ðŸ›¡ï¸ Get â‚¹1 Cr term insurance + â‚¹10L health cover. Monthly cost is just â‚¹1,500â€“2,500. This is non-negotiable.`});
    if(tax==='none'||tax==='partial') alerts.push({type:'info',msg:`ðŸ“‹ Maximise Section 80C (â‚¹1.5L via ELSS/PPF) + NPS Tier 1 (â‚¹50K extra deduction). Saves â‚¹46,800+ in taxes annually.`});
    if(retire==='none'||retire==='epf') alerts.push({type:'info',msg:`ðŸŒ… Start a retirement SIP today. â‚¹5,000/month at age 28 â†’ â‚¹3.2 Cr at 60 (at 12% returns). Time is your biggest asset.`});
    if(debt > income*12) alerts.push({type:'warn',msg:`ðŸ’³ Debt-to-income ratio is high. Prioritise repaying high-interest debt (credit cards, personal loans) before increasing investments.`});
    if(alerts.length===0) alerts.push({type:'good',msg:`âœ… Excellent fundamentals! Focus on optimising returns â€” review fund performance, explore NPS for extra tax saving, and consider REITs for diversification.`});

    document.getElementById('alerts-container').innerHTML = alerts.slice(0,3).map(a=>
      `<div class="alert alert-${a.type}">${a.msg}</div>`).join('');

    // SIP table
    const investable = Math.max(income*0.2, sip);
    const sipRows = [
      {goal:'Emergency Top-up',type:'Liquid Fund / Overnight Fund',amt:Math.round(investable*0.15)},
      {goal:'Wealth Creation (10Y+)',type:'Large & Mid Cap / Flexicap',amt:Math.round(investable*0.40)},
      {goal:'Tax Saving (ELSS)',type:'ELSS Fund (80C)',amt:Math.round(Math.min(investable*0.25,12500))},
      {goal:'Retirement',type:'NPS Tier 1 + Equity Fund',amt:Math.round(investable*0.20)},
    ];
    document.getElementById('sip-tbody').innerHTML = sipRows.map(r=>
      `<tr><td>${r.goal}</td><td style="color:var(--muted)">${r.type}</td><td>${fmt(r.amt)}</td></tr>`
    ).join('');
  }

  function animateScore(target){
    const el = document.getElementById('score-num');
    const arc = document.getElementById('score-arc');
    let current = 0;
    const step = target/60;
    const timer = setInterval(()=>{
      current = Math.min(current+step, target);
      el.textContent = Math.round(current);
      const offset = 440*(1-current/100);
      arc.style.strokeDashoffset = offset;
      if(current>=target) clearInterval(timer);
    },16);
  }

  // â”€â”€ FIRE PLANNER â”€â”€
  function calculateFIRE(){
    const age       = +document.getElementById('f-age').value;
    const retAge    = +document.getElementById('f-retire-age').value;
    const income    = +document.getElementById('f-income').value;
    const expenses  = +document.getElementById('f-exp').value;
    const corpus0   = +document.getElementById('f-corpus').value;
    const ret       = +document.getElementById('f-return').value/100;
    const infl      = +document.getElementById('f-inflation').value/100;
    const life      = +document.getElementById('f-life').value;

    const yearsToFIRE = retAge - age;
    const retirementYears = life - retAge;
    const realRet   = (1+ret)/(1+infl)-1;

    // Monthly expenses at retirement (inflation-adjusted)
    const futureExp = expenses * Math.pow(1+infl, yearsToFIRE);
    // 4% SWR corpus needed
    const corpusNeeded = futureExp*12/0.04;
    // Current corpus grown
    const corpusGrown = corpus0 * Math.pow(1+ret, yearsToFIRE);
    // Monthly SIP needed
    const monthlyRet = ret/12;
    const n = yearsToFIRE*12;
    const gap = corpusNeeded - corpusGrown;
    const sipNeeded = gap > 0 ? gap*monthlyRet/(Math.pow(1+monthlyRet,n)-1) : 0;
    const currentSavings = income - expenses;
    const savingsRate = Math.round(currentSavings/income*100);

    document.getElementById('fire-result').classList.add('show');

    document.getElementById('fire-cards').innerHTML = [
      {icon:'ðŸŽ¯', val:fmt(Math.round(corpusNeeded/100000)*100000), lbl:'FIRE Corpus Needed'},
      {icon:'ðŸ“…', val:retAge+' years old', lbl:'Your FIRE Target Age'},
      {icon:'ðŸ’°', val:fmt(Math.round(sipNeeded/100)*100)+'/mo', lbl:'Monthly SIP Required'},
      {icon:'ðŸ“Š', val:savingsRate+'%', lbl:'Current Savings Rate'},
      {icon:'â³', val:yearsToFIRE+' years', lbl:'Years to FIRE'},
      {icon:'ðŸŒ…', val:fmt(Math.round(futureExp)), lbl:'Monthly Exp at Retirement'},
    ].map(c=>`<div class="fire-card"><div class="fire-icon">${c.icon}</div><div class="fire-val">${c.val}</div><div class="fire-lbl">${c.lbl}</div></div>`).join('');

    // Timeline
    const milestones = [];
    const now = new Date().getFullYear();
    milestones.push({yr:now, action:`Start SIP of ${fmt(Math.round(sipNeeded/100)*100)}/month`, detail:`Mix: 60% equity, 30% hybrid, 10% debt`});
    if(yearsToFIRE>=5) milestones.push({yr:now+3, action:'First â‚¹10L milestone review', detail:'Rebalance portfolio, increase SIP by 10% annually'});
    if(yearsToFIRE>=8) milestones.push({yr:now+Math.round(yearsToFIRE*0.4), action:'Halfway corpus check', detail:`Should have ${fmt(Math.round(corpusNeeded*0.35))} by now`});
    milestones.push({yr:now+yearsToFIRE-2, action:'Pre-FIRE preparation', detail:'Shift 30% to debt/FD. Review withdrawal strategy'});
    milestones.push({yr:now+yearsToFIRE, action:'ðŸŽ‰ FIRE Achieved!', detail:`Corpus: ${fmt(Math.round(corpusNeeded))} â€” Start 4% annual withdrawal`});
    if(retirementYears>10) milestones.push({yr:now+yearsToFIRE+10, action:'Mid-retirement review', detail:'Adjust SWR based on portfolio performance & inflation'});

    document.getElementById('fire-timeline').innerHTML = milestones.map(m=>`
      <div class="tl-item">
        <div class="tl-dot"></div>
        <div class="tl-content">
          <div class="tl-year">${m.yr}</div>
          <div class="tl-action">${m.action}</div>
          <div class="tl-detail">${m.detail}</div>
        </div>
      </div>
    `).join('');

    // Tips
    const tips = [];
    if(savingsRate<30) tips.push({type:'warn',msg:`ðŸ“‰ Your savings rate is ${savingsRate}%. FIRE typically needs 40-50%+. Consider cutting discretionary expenses by â‚¹${fmt(Math.round(income*0.1))}/month.`});
    if(sipNeeded > currentSavings) tips.push({type:'warn',msg:`âš ï¸ Required SIP (${fmt(Math.round(sipNeeded))}) exceeds your current monthly savings (${fmt(currentSavings)}). Consider delaying FIRE by 2-3 years or increasing income.`});
    tips.push({type:'good',msg:`ðŸ’¡ Step-up SIP by 10% annually. Your target corpus reduces by ~${fmt(Math.round(corpusNeeded*0.15))} if you increase SIP 10% each year from today.`});
    tips.push({type:'info',msg:`ðŸ  If you have a home loan, balance prepayment vs investing. If loan rate < 8.5%, investing in equity likely wins long-term.`});
    tips.push({type:'info',msg:`ðŸ“‹ Max out NPS Tier 1 for the extra â‚¹50,000 deduction â€” saves â‚¹15,600 annually in taxes which can go back into your FIRE corpus.`});

    document.getElementById('fire-tips').innerHTML = tips.map(t=>
      `<div class="alert alert-${t.type}">${t.msg}</div>`).join('');
  }

  // â”€â”€ AI CHAT â”€â”€
  const SYSTEM_PROMPT = `You are ET Money Mentor â€” an expert AI financial advisor for Indian retail investors. 
You know Indian tax laws, investment products (SIP, ELSS, NPS, PPF, FD, REITs, SGBs, ETFs), SEBI regulations, 
insurance products, and personal finance best practices deeply. 
Respond concisely (3-5 sentences max), always in simple English, with specific Indian context. 
Include rupee amounts, percentage benchmarks, and actionable next steps. 
Never give generic advice â€” always be specific and useful. 
If asked about specific stocks, remind the user you don't recommend individual stocks but can discuss sectors or index funds.`;

  let chatHistory = [];

  async function sendChat(){
    const input = document.getElementById('chat-in');
    const msg = input.value.trim();
    if(!msg) return;
    input.value='';
    addMsg('user', msg);
    chatHistory.push({role:'user', content:msg});
    const typingId = addTyping();
    try {
      const resp = await fetch('https://api.anthropic.com/v1/messages',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({
          model:'claude-sonnet-4-20250514',
          max_tokens:1000,
          system: SYSTEM_PROMPT,
          messages: chatHistory
        })
      });
      const data = await resp.json();
      removeTyping(typingId);
      const reply = data.content?.[0]?.text || "Sorry, I couldn't process that. Please try again.";
      chatHistory.push({role:'assistant', content:reply});
      addMsg('bot', reply);
    } catch(e){
      removeTyping(typingId);
      addMsg('bot','âš ï¸ Connection issue. Please check your internet and try again.');
    }
  }

  function sendQuick(q){ document.getElementById('chat-in').value=q; sendChat(); showTab('chat'); }

  function addMsg(who, text){
    const w = document.getElementById('chat-window');
    const d = document.createElement('div');
    d.className='msg'+(who==='user'?' user':'');
    d.innerHTML=`<div class="msg-avatar">${who==='user'?'ðŸ‘¤':'ðŸ¤–'}</div>
      <div class="msg-bubble">${text.replace(/\n/g,'<br/>')}</div>`;
    w.appendChild(d);
    w.scrollTop = w.scrollHeight;
  }

  function addTyping(){
    const w = document.getElementById('chat-window');
    const id = 'typing-'+Date.now();
    const d = document.createElement('div');
    d.className='msg'; d.id=id;
    d.innerHTML=`<div class="msg-avatar">ðŸ¤–</div>
      <div class="msg-bubble"><div class="typing"><span></span><span></span><span></span></div></div>`;
    w.appendChild(d); w.scrollTop=w.scrollHeight;
    return id;
  }
  function removeTyping(id){ const el=document.getElementById(id); if(el) el.remove(); }

  // NAV sync
  function showSection(s){
    ['health','fire','chat'].forEach(x=>{
      document.getElementById('panel-'+x).classList.remove('active');
      document.getElementById('tab-'+x).classList.remove('active');
    });
    document.getElementById('panel-'+s).classList.add('active');
    document.getElementById('tab-'+s).classList.add('active');
    ['health','fire','chat'].forEach(b=>{
      document.querySelector(`button.nav-btn[onclick="showSection('${b}')"]`)?.classList.remove('active');
    });
    document.querySelector(`button.nav-btn[onclick="showSection('${s}')"]`)?.classList.add('active');
  }
</script>
